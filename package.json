{
  "name": "@facturion/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Facturion's open-source packages (MIT). Monorepo home for @facturion/codelists and future siblings (e.g. @facturion/invoice-renderer).",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "generate": "npm run generate --workspaces --if-present",
    "typecheck": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
